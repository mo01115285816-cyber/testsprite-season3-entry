# ============================================================
# TestSprite Hackathon Season 3 — Environment Variables
# ============================================================
# Copy this file to `.env.local` (NEVER commit the real one).
# Fill in the values the user provides, then run:
#   testsprite setup --from-env --yes --agent claude
# ============================================================

# Your TestSprite API key (from app.testsprite.com → Settings → API Keys).
# Format: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TESTSPRITE_API_KEY=

# Once you create a project on TestSprite, paste its id here.
# Format: proj_xxxxxxxxxxxxxxxx
TESTSPRITE_PROJECT_ID=

# Your project type: frontend | backend
TESTSPRITE_PROJECT_TYPE=frontend

# The PUBLIC live URL of your deployed app (no localhost).
# The CLI tests in the cloud against this URL.
TESTSPRITE_TARGET_URL=

# Optional: a friendly name for the project on the TestSprite dashboard.
TESTSPRITE_PROJECT_NAME=

# NEXUS — Gemini API key (get one free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
